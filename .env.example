APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# OpenStreetMap Overpass API (https://overpass-api.de/api/interpreter)
OVERPASS_INTERPRETER_URL=https://overpass-api.de/api/interpreter
# OVERPASS_TIMEOUT=28
# OVERPASS_RADIUS_METERS=15000
# OVERPASS_MAX_RESULTS=80
# OVERPASS_USER_AGENT="SemaNami/1 (+https://www.openstreetmap.org/copyright)"

# Safe Girl — optional override; default URL is set in config/safe_girl.php
# SAFE_GIRL_WEBHOOK_URL=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting:
# - `null` / `log` — no live WebSockets (Echo will not connect).
# - `pusher` — Pusher Channels (good for cPanel shared hosting; no server process). Set PUSHER_* below, then `npm run build`.
# - `reverb` — self-hosted WebSockets; run `php artisan reverb:start` locally or on a VPS with Supervisor.
BROADCAST_CONNECTION=null

# Pusher Channels (https://dashboard.pusher.com/) — use with BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
# Optional overrides (defaults work for Pusher Cloud):
# PUSHER_HOST=
# PUSHER_PORT=443
PUSHER_SCHEME=https

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSockets for Echo). Generate keys with `php artisan reverb:install`.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Vite fallbacks if meta tags are missing (e.g. some edge layouts). Prefer server meta from role-dashboard.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Jitsi (macellan/laravel-jitsi package defaults; override if you self-host meet)
# JITSI_DOMAIN=meet.jit.si
# JITSI_EXTERNAL_API_URL=https://meet.jit.si/external_api.js

# Super-Admin security defaults
ADMIN_REQUIRE_SUPERADMIN_MFA=true
ADMIN_IP_ALLOWLIST_ENABLED=false
# Comma separated IPs or CIDR ranges, e.g. "127.0.0.1,10.0.0.0/24"
ADMIN_IP_ALLOWLIST=
